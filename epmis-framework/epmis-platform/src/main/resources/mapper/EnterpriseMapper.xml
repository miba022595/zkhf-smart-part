        <result property="entName" column="ent_name"/>
        <result property="socialCreditCode" column="social_credit_code"/>
        <result property="shorterName" column="shorter_name"/>
        <result property="legalPerson" column="legal_person"/>
        <result property="region" column="region"/>
        <result property="address" column="address"/>
        <result property="longitude" column="longitude"/>
        <result property="latitude" column="latitude"/>
        <result property="entStatus" column="ent_status"/>
        <result property="entScale" column="ent_scale"/>
        <result property="entType" column="ent_type"/>
        <result property="industryType" column="industry_type"/>
        <result property="pollutionClass" column="pollution_class"/>
        <result property="entDirectorName" column="ent_director_name"/>
        <result property="entDirectorPhone" column="ent_director_phone"/>
        <result property="entDirectorEmail" column="ent_director_email"/>
        <result property="envDirectorName" column="env_director_name"/>
        <result property="envDirectorPhone" column="env_director_phone"/>
        <result property="envDirectorEmail" column="env_director_email"/>
        <result property="entIntroduction" column="ent_introduction"/>
        <result property="weComMsg" column="we_com_msg"/>
        <result property="envPolicyName" column="env_policy_name"/>
        <result property="envPolicyDate" column="env_policy_date"/>
        <result property="envPolicyLevel" column="env_policy_level"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <resultMap id="enterprisePartResult" type="com.zkhf.epmis.platform.ent.domain.EnterprisePart">
        <result property="entCode" column="ent_code"/>
        <result property="parentCode" column="parent_code"/>
        <result property="entName" column="ent_name"/>
        <result property="socialCreditCode" column="social_credit_code"/>
        <result property="shorterName" column="shorter_name"/>
        <result property="longitude" column="longitude"/>
        <result property="latitude" column="latitude"/>
        <result property="region" column="region"/>
        <result property="entDirectorName" column="ent_director_name"/>
        <result property="entDirectorPhone" column="ent_director_phone"/>
        <result property="entDirectorEmail" column="ent_director_email"/>
    </resultMap>

    <resultMap id="entPartTreeResult" type="com.zkhf.epmis.platform.ent.domain.EnterprisePart">
        <result property="entCode" column="ent_code"/>
        <result property="parentCode" column="parent_code"/>
        <result property="entName" column="ent_name"/>
        <result property="socialCreditCode" column="social_credit_code"/>
        <result property="shorterName" column="shorter_name"/>
        <result property="longitude" column="longitude"/>
        <result property="latitude" column="latitude"/>
        <result property="region" column="region"/>
        <!-- 映射排口数组 -->
        <collection property="outList" ofType="com.zkhf.epmis.platform.ent.domain.EntOutPutPart">
            <result property="outPutId" column="out_put_id"/>
            <result property="outPutCode" column="out_put_code"/>
            <result property="outPutName" column="out_put_name"/>
            <result property="outPutType" column="out_put_type"/>
            <result property="longitude" column="longitude"/>
            <result property="latitude" column="latitude"/>
            <result property="clockRange" column="clock_range"/>
        </collection>
    </resultMap>

    <!-- 企业树 -->
    <resultMap id="outPutTreeResult" type="java.util.Map">
        <result property="entCode" column="ent_code"/>
        <result property="parentCode" column="parent_code"/>
        <result property="entName" column="ent_name"/>
        <!-- 映射排口数组 -->
        <collection property="outPutList" ofType="java.util.Map" javaType="java.util.List">
            <result property="outPutId" column="out_put_id"/>
            <result property="outPutCode" column="out_put_code"/>
            <result property="outPutName" column="out_put_name"/>
            <result property="outPutType" column="out_put_type"/>
            <result property="longitude" column="longitude"/>
            <result property="latitude" column="latitude"/>
            <result property="clockRange" column="clock_range"/>
        </collection>
    </resultMap>

    <select id="listAll" resultMap="enterprisePartResult">
        select
            ent_code, parent_code, ent_name, ent_director_name, ent_director_phone, ent_director_email
        from t_bas_enterprise
    </select>

    <select id="selectPartListByPollType" resultMap="enterprisePartResult">
        select
            e.ent_code, e.parent_code, e.ent_name, e.social_credit_code, e.shorter_name
        from t_bas_enterprise e
        <where>
            <if test="entCodes != null and entCodes.size() > 0">
                and e.ent_code in
                <foreach collection="entCodes" item="entCode" open="(" separator="," close=")">
                    #{entCode}
                </foreach>
            </if>
            <if test="pollType != null and pollType != ''">
                and exists (select 1 from t_ent_out_put_info where ent_code = e.ent_code and out_put_type = #{pollType})
            </if>
        </where>
        order by e.parent_code desc, e.ent_code desc
    </select>

    <select id="selectPartListByRegion" resultMap="enterprisePartResult">
        select
            e.ent_code, e.parent_code, e.ent_name, e.social_credit_code, e.shorter_name, e.region
        from t_bas_enterprise e
        <where>
            <if test="entCodes != null and entCodes.size() > 0">
                and e.ent_code in
                <foreach collection="entCodes" item="entCode" open="(" separator="," close=")">
                    #{entCode}
                </foreach>
            </if>
            <if test="region != null and region != ''">
                and (e.region = #{region} or e.region like CONCAT(#{region}, ',%'))
            </if>
        </where>
        order by e.parent_code desc, e.ent_code desc
    </select>

    <select id="outPutTree" resultMap="outPutTreeResult">
        select
            e.ent_code, e.parent_code, e.ent_name, o.out_put_id, o.out_put_code, o.out_put_name, o.out_put_type, o.longitude, o.latitude, o.clock_range
        from t_bas_enterprise e inner join t_ent_out_put_info o on o.ent_code = e.ent_code
        <where>
            <choose>
                <when test="entCode != null and entCode != ''">
                    and e.ent_code = #{entCode}
                </when>
                <otherwise>
                    <if test="entCodes != null and entCodes.size() > 0">
                        and e.ent_code in
                        <foreach collection="entCodes" item="entCode" open="(" separator="," close=")">
                            #{entCode}
                        </foreach>
                    </if>
                </otherwise>
            </choose>
            <if test="entName != null and entName != ''">
                and e.ent_name like concat('%', #{entName}, '%')
            </if>
            <if test="outPutId != null and outPutId != ''">
                and o.out_put_id = #{outPutId}
            </if>
            <if test="outPutCode != null and outPutCode != ''">
                and o.out_put_code like concat('%', #{outPutCode}, '%')
            </if>
            <if test="outPutName != null and outPutName != ''">
                and o.out_put_name like concat('%', #{outPutName}, '%')
            </if>
            <if test="outPutType != null">
                and o.out_put_type = #{outPutType}
            </if>
        </where>
        order by e.parent_code desc, e.ent_code desc, o.out_put_id desc
    </select>

    <select id="outPutTreeByEnt" resultMap="entPartTreeResult">
        select
            e.ent_code, e.parent_code, e.ent_name, e.social_credit_code, e.shorter_name, e.longitude, e.latitude,
            o.out_put_id, o.out_put_code, o.out_put_name, o.out_put_type, o.longitude, o.latitude, o.clock_range
        from t_bas_enterprise e inner join t_ent_out_put_info o on o.ent_code = e.ent_code
        <where>
            <if test="entCodes != null and entCodes.size() > 0">
                and e.ent_code in
                <foreach collection="entCodes" item="entCode" open="(" separator="," close=")">
                    #{entCode}
                </foreach>
            </if>
            <if test="pollType != null and pollType != ''">
                and o.out_put_type = #{pollType}
            </if>
        </where>
        order by e.parent_code desc, e.ent_code desc, o.out_put_id desc
    </select>

    <select id="outPutTreeByRegion" resultMap="entPartTreeResult">
        select
            e.ent_code, e.parent_code, e.ent_name, e.social_credit_code, e.shorter_name, e.longitude, e.latitude, e.region,
            o.out_put_id, o.out_put_code, o.out_put_name, o.out_put_type, o.longitude, o.latitude, o.clock_range
        from t_bas_enterprise e inner join t_ent_out_put_info o on o.ent_code = e.ent_code
        <where>
            <if test="entCodes != null and entCodes.size() > 0">
                and e.ent_code in
                <foreach collection="entCodes" item="entCode" open="(" separator="," close=")">
                    #{entCode}
                </foreach>
            </if>
        </where>
        order by e.parent_code desc, e.ent_code desc, o.out_put_id desc
    </select>

    <select id="selectPartListAll" resultMap="enterprisePartResult">
        select
            ent_code, parent_code, ent_name, social_credit_code, shorter_name, longitude, latitude
        from t_bas_enterprise
        <where>
            <if test="entCodes != null and entCodes.size() > 0">
                and ent_code in
                <foreach collection="entCodes" item="entCode" open="(" separator="," close=")">
                    #{entCode}
                </foreach>
            </if>
        </where>
        order by parent_code desc, ent_code desc
    </select>

    <select id="selectList" parameterType="com.zkhf.epmis.platform.ent.domain.EnterpriseReq"
            resultMap="enterpriseResult">
        select
            ent_code, parent_code, ent_name, social_credit_code, shorter_name, legal_person, region, address, longitude, latitude, ent_status, ent_scale,
            ent_type, industry_type, pollution_class, ent_director_name, ent_director_phone, ent_director_email, env_director_name, env_director_phone, env_director_email, ent_introduction,
            we_com_msg, env_policy_name, env_policy_date, env_policy_level, create_time, update_time
        from t_bas_enterprise
        <where>
            <choose>
                <when test="entCode != null and entCode != ''">
                    and ent_code = #{entCode}
                </when>
                <otherwise>
                    <if test="entCodes != null and entCodes.size() > 0">
                        AND ent_code in
                        <foreach collection="entCodes" item="entCode" open="(" separator="," close=")">
                            #{entCode}
                        </foreach>
                    </if>
                </otherwise>
            </choose>
            <if test="entName != null and entName != ''">and ent_name like concat('%', #{entName}, '%')</if>
            <if test="entStatus != null and entStatus != ''">and ent_status = #{entStatus}</if>
        </where>
        order by parent_code desc, ent_code desc
    </select>

