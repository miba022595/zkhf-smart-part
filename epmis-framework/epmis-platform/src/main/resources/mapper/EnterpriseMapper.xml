    <update id="updateEnterprise" parameterType="com.zkhf.epmis.platform.ent.domain.Enterprise">
        update t_bas_enterprise
        <trim prefix="SET" suffixOverrides=",">
            <if test="entName != null">ent_name = #{entName},</if>
            <if test="socialCreditCode != null">social_credit_code = #{socialCreditCode},</if>
            <if test="shorterName != null">shorter_name = #{shorterName},</if>
            <if test="legalPerson != null">legal_person = #{legalPerson},</if>
            <if test="region != null">region = #{region},</if>
            <if test="address != null">address = #{address},</if>
            <if test="longitude != null">longitude = #{longitude},</if>
            <if test="latitude != null">latitude = #{latitude},</if>
            <if test="entStatus != null">ent_status = #{entStatus},</if>
            <if test="entScale != null">ent_scale = #{entScale},</if>
