        </trim>
        where ent_code = #{entCode}
    </update>

    <select id="selectListByParentCode">
        select
            ent_code, parent_code, ent_name, social_credit_code, shorter_name, legal_person, region, address, longitude, latitude, ent_status, ent_scale,
            ent_type, industry_type, pollution_class, ent_director_name, ent_director_phone, ent_director_email, env_director_name, env_director_phone, env_director_email, ent_introduction,
            we_com_msg, env_policy_name, env_policy_date, env_policy_level, create_time, update_time
        from t_bas_enterprise
        where parent_code = #{parentCode}
        order by ent_code desc
    </select>

    <delete id="deleteEnterpriseById">
        delete from t_bas_enterprise where ent_code = #{entCode}
    </delete>

    <delete id="deleteEntOutputAtt">
        delete u from t_bas_user_put_info u
        left join t_ent_out_put_info e on u.out_put_id = e.out_put_id
        where e.ent_code = #{entCode}
    </delete>

    <delete id="deleteEntOutputPoll">
        delete u from t_ent_output_pollutant u
        left join t_ent_out_put_info e on u.out_put_id = e.out_put_id
        where e.ent_code = #{entCode}
    </delete>

    <delete id="deleteEntOutput">
        delete from t_ent_out_put_info where ent_code = #{entCode}
    </delete>

    <delete id="deleteUserEnt">
        delete from sys_user_ent where ent_code = #{entCode}
    </delete>
</mapper>
