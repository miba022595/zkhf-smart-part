<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zkhf.epmis.platform.mapper.emergency.EmergencyPlanMapper">

    <resultMap id="emergencyPlanResult" type="com.zkhf.epmis.platform.emergency.domain.EmergencyPlan">
        <result property="planId" column="plan_id"/>
        <result property="entCode" column="ent_code"/>
        <result property="entName" column="ent_name"/>
        <result property="weComMsg" column="we_com_msg"/>
        <result property="planName" column="plan_name"/>
        <result property="version" column="version"/>
        <result property="riskUnit" column="risk_unit"/>
        <result property="handlePoints" column="handle_points"/>
        <result property="planType" column="plan_type"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <insert id="insert" parameterType="com.zkhf.epmis.platform.emergency.domain.EmergencyPlan">
        insert into t_emergency_plan
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="planId != null and planId != ''">plan_id,</if>
            <if test="entCode != null and entCode != ''">ent_code,</if>
            <if test="planName != null and planName != ''">plan_name,</if>
            <if test="version != null and version != ''">version,</if>
            <if test="riskUnit != null and riskUnit != ''">risk_unit,</if>
            <if test="handlePoints != null and handlePoints != ''">handle_points,</if>
            <if test="planType != null">plan_type,</if>
            <if test="remark != null and remark != ''">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="planId != null and planId != ''">#{planId},</if>
            <if test="entCode != null and entCode != ''">#{entCode},</if>
            <if test="planName != null and planName != ''">#{planName},</if>
            <if test="version != null and version != ''">#{version},</if>
            <if test="riskUnit != null and riskUnit != ''">#{riskUnit},</if>
            <if test="handlePoints != null and handlePoints != ''">#{handlePoints},</if>
            <if test="planType != null">#{planType},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
        </trim>
    </insert>

    <insert id="batchInsert">
        insert into t_emergency_plan
            (plan_id, ent_code, plan_name, version, risk_unit, handle_points, plan_type, remark)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.planId}, #{item.entCode}, #{item.planName}, #{item.version}, #{item.riskUnit}, #{item.handlePoints}, #{item.planType}, #{item.remark})
        </foreach>
    </insert>

    <update id="update" parameterType="com.zkhf.epmis.platform.emergency.domain.EmergencyPlan">
        update t_emergency_plan
        <trim prefix="SET" suffixOverrides=",">
            <if test="planName != null and planName != ''">plan_name = #{planName},</if>
            <if test="version != null and version != ''">version = #{version},</if>
            <if test="riskUnit != null and riskUnit != ''">risk_unit = #{riskUnit},</if>
            <if test="handlePoints != null and handlePoints != ''">handle_points = #{handlePoints},</if>
            <if test="planType != null">plan_type = #{planType},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
        </trim>
        where plan_id = #{planId}
    </update>

    <delete id="deleteById">
        delete from t_emergency_plan where plan_id = #{planId}
    </delete>

    <select id="selectById" resultMap="emergencyPlanResult">
        select p.*, e.ent_name, e.we_com_msg from t_emergency_plan p
        left join t_bas_enterprise e on p.ent_code = e.ent_code
        where p.plan_id = #{planId}
    </select>

    <select id="selectList" resultMap="emergencyPlanResult">
        select p.*, e.ent_name, e.we_com_msg from t_emergency_plan p
        left join t_bas_enterprise e on p.ent_code = e.ent_code
        <where>
            <choose>
                <when test="entCode != null and entCode != ''">
                    and p.ent_code = #{entCode}
                </when>
                <otherwise>
                    <if test="entCodes != null and entCodes.size() > 0">
                        and p.ent_code in
                        <foreach collection="entCodes" item="entCode" open="(" separator="," close=")">
                            #{entCode}
                        </foreach>
                    </if>
                </otherwise>
            </choose>
            <if test="planId != null and planId != ''">
                and p.plan_id = #{planId}
            </if>
            <if test="planName != null and planName != ''">
                and p.plan_name like concat('%', #{planName}, '%')
            </if>
            <if test="version != null and version != ''">
                and p.version like concat('%', #{version}, '%')
            </if>
            <if test="riskUnit != null and riskUnit != ''">
                and p.risk_unit like concat('%', #{riskUnit}, '%')
            </if>
            <if test="planType != null">
                and p.plan_type = #{planType}
            </if>
        </where>
        order by p.create_time desc
    </select>

    <select id="selectAll" resultMap="emergencyPlanResult">
        select p.*, e.ent_name, e.we_com_msg from t_emergency_plan p
        left join t_bas_enterprise e on p.ent_code = e.ent_code
        order by p.create_time desc
    </select>
</mapper>